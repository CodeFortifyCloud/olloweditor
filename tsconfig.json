{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "declaration": false,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "src/**/*.js",
    "src/**/*.jsx",
    "src/types/**/*.d.ts",
    "examples/**/*.ts",
    "examples/**/*.tsx"
  ]
}
